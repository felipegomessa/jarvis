# JARVIS Acadêmico — variáveis de ambiente
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commitar .env (já está no .gitignore).

# ---------- LLM (Qwen2.5-14B-Instruct-AWQ via LIA UFMS) ----------
JARVIS_LLM_BASE_URL=https://llm.liaufms.org/v1/qwen2-5-14b-instruct-awq
JARVIS_LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
JARVIS_LLM_API_KEY=cole_aqui_o_token_fornecido_pelo_professor
JARVIS_LLM_TIMEOUT_S=60
JARVIS_LLM_MAX_TOKENS=2048
JARVIS_LLM_TEMPERATURE=0.2

# ---------- Banco de Dados (SQLite local) ----------
JARVIS_DB_PATH=./data/jarvis.db

# ---------- RAG / Embeddings ----------
JARVIS_EMBED_MODEL=intfloat/multilingual-e5-small
JARVIS_CHUNK_SIZE=800
JARVIS_CHUNK_OVERLAP=150
JARVIS_RAG_TOP_K=5
JARVIS_RAG_DISTANCE_THRESHOLD=0.6

# ---------- Logging ----------
JARVIS_LOG_LEVEL=INFO
JARVIS_LOG_DIR=./logs

# ---------- UI ----------
JARVIS_UI_HOST=127.0.0.1
JARVIS_UI_PORT=8080
JARVIS_UI_DARK=true
